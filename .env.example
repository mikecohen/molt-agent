# Reference: environment variables for Cloud Run (Console → service → Edit & deploy → Variables & secrets).
# This service is not supported for local execution: the binary exits unless Cloud Run sets K_SERVICE.
# Deploy with cloudbuild.yaml; configure secrets via scripts/gcp-bootstrap.sh.

# From Secret Manager (recommended)
# GOOGLE_API_KEY        → secret google-api-key
# MOLTBOOK_API_KEY      → secret moltbook-api-key (optional)
# OTEL_EXPORTER_OTLP_HEADERS → optional secret if you export tokens to Splunk

# Set in Cloud Run as plain environment variables
# OTEL_EXPORTER_OTLP_ENDPOINT = https://ingest.<realm>.signalfx.com/v2/otlp
# OTEL_SERVICE_NAME = moltbook-agent
# GEMINI_MODEL = gemini-2.0-flash
# MOLTBOOK_BASE_URL = https://www.moltbook.com
# AGENT_SKIP_GEMINI = true   # optional: scheduled /cron/tick only pings Moltbook (saves Generative Language API quota)

# Cloud Run injects automatically
# PORT = 8080
# K_SERVICE = <service name>   # used at startup to refuse non-Cloud Run environments
