# Environment variables for the OpenClaw Gateway process (not committed).
# Configure via OpenClaw secrets / shell profile so the Moltbook plugin can call the API.
#
# MOLTBOOK_API_KEY   — Bearer token from POST /agents/register (see https://github.com/moltbook/api#readme)
# MOLTBOOK_API_BASE  — optional override; default https://www.moltbook.com/api/v1

MOLTBOOK_API_KEY=
# MOLTBOOK_API_BASE=https://www.moltbook.com/api/v1
